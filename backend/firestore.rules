rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ────────────────────────────────────────────────────
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    function isAdmin() {
      return isAuthenticated() && request.auth.token.admin == true;
    }

    // ── Users ───────────────────────────────────────────────────────────────
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if false; // only Cloud Functions write user docs
    }

    // ── Chickens ────────────────────────────────────────────────────────────
    match /chickens/{chickenId} {
      allow read: if isAuthenticated() &&
        (resource.data.ownerId == request.auth.uid || isAdmin());
      allow write: if false; // only Cloud Functions write chicken docs
    }

    // ── Eggs ────────────────────────────────────────────────────────────────
    match /eggs/{eggId} {
      allow read: if isAuthenticated() &&
        (resource.data.ownerId == request.auth.uid || isAdmin());
      allow write: if false; // only Cloud Functions write egg docs
    }

    // ── Unique Modifier Registry ─────────────────────────────────────────────
    match /unique_modifier_registry/{tag} {
      allow read: if isAuthenticated();
      allow write: if false; // only Cloud Functions manage this registry
    }

    // ── Respec History ──────────────────────────────────────────────────────
    match /respec_history/{historyId} {
      allow read: if isAuthenticated() &&
        (resource.data.actorUserId == request.auth.uid || isAdmin());
      allow write: if false;
    }

    // ── Breeding History ────────────────────────────────────────────────────
    match /breeding_history/{historyId} {
      allow read: if isAuthenticated() &&
        (resource.data.actorId == request.auth.uid || isAdmin());
      allow write: if false;
    }

    // ── Archetype Candidates ─────────────────────────────────────────────────
    match /archetype_candidates/{candidateId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // ── Idempotency Tokens (internal only) ──────────────────────────────────
    match /idempotency_tokens/{tokenId} {
      allow read, write: if false;
    }

    // ── Bans (admin only) ────────────────────────────────────────────────────
    match /bans/{banId} {
      allow read, write: if isAdmin();
    }

    // ── Telemetry Events (write-only for authenticated users, admin read) ────
    match /telemetry_events/{eventId} {
      allow read: if isAdmin();
      allow write: if false; // only Cloud Functions write telemetry
    }

    // ── Default: deny all ───────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
